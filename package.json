{
  "name": "JavaScriptAi",
  "displayName": "JavaScriptAi",
  "publisher": "KeshavSoft",
  "description": "KeshavSoft AI with voice capture",
  "version": "1.13.1",
  "type": "module",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keshavsoft/keshavai.git"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.build",
        "title": "Build"
      },
      {
        "command": "extension.initJs",
        "title": "Initiate JS"
      },
      {
        "command": "extension.addListeners",
        "title": "Initiate addListeners"
      },
      {
        "command": "extension.addBusiness",
        "title": "Initiate addBusiness"
      },
      {
        "command": "extension.FetchCalls",
        "title": "Initiate FetchCalls"
      },
      {
        "command": "extension.fetchFromServer",
        "title": "Initiate fetchFromServer"
      },
      {
        "command": "extension.fetchCommand",
        "title": "Initiate fetchCommand"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.build",
          "when": "explorerResourceIsFolder",
          "group": "navigation@1"
        },
        {
          "command": "extension.initJs",
          "when": "resourceExtname == .html",
          "group": "navigation@2"
        },
        {
          "command": "extension.addListeners",
          "when": "resourceExtname == .html",
          "group": "navigation@3"
        },
        {
          "command": "extension.addBusiness",
          "when": "resourceExtname == .html",
          "group": "navigation@4"
        },
        {
          "command": "extension.FetchCalls",
          "when": "resourceExtname == .html",
          "group": "navigation@5"
        },
        {
          "command": "extension.fetchFromServer",
          "when": "resourceExtname == .html",
          "group": "navigation@6"
        },
        {
          "command": "extension.fetchCommand",
          "when": "resourceExtname == .html",
          "group": "navigation@7"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.3",
    "postcss": "^8.5.8"
  }
}